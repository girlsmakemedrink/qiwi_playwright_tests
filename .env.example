# Скопируйте этот файл в .env и заполните значения.
# .env добавлен в .gitignore и не попадёт в репозиторий.

# Базовый URL API (по умолчанию — продовый хост QIWI из документации)
QIWI_BASE_URL=https://edge.qiwi.com

# Токен API QIWI Кошелька (Bearer)
QIWI_API_TOKEN=test-token

# Номер вашего кошелька без знака "+", напр. 79991234567
QIWI_WALLET=79991234567

# Кошелёк-получатель для тестового платёжа (P2P-перевод)
QIWI_RECIPIENT_WALLET=79997654321
